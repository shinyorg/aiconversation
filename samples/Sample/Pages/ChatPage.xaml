<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chat="clr-namespace:Shiny.Maui.Controls.Chat;assembly=Shiny.Maui.Controls"
             xmlns:pages="clr-namespace:Sample.Pages"
             x:Class="Sample.Pages.ChatPage"
             x:DataType="pages:ChatViewModel"
             Title="Chat">

    <chat:ChatView Messages="{Binding Messages}"
                   Participants="{Binding Participants}"
                   ShowAvatarsInSingleChat="True"
                   SendCommand="{Binding SendCommand}"
                   LoadMoreCommand="{Binding LoadMoreCommand}"
                   ChatBackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource OffBlack}}"
                   MyBubbleColor="{StaticResource Primary}"
                   MyTextColor="White"
                   OtherBubbleColor="{AppThemeBinding Light=#F0EEFF, Dark=#2A2854}"
                   OtherTextColor="{AppThemeBinding Light=#1A1A2E, Dark=#E8E5FF}"
                   BubbleFontSize="15"
                   BubbleCornerRadius="16"
                   TimestampFontSize="11"
                   SendButtonBackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                   SendButtonTextColor="White"
                   InputBarBackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                   InputBarBorderColor="{AppThemeBinding Light={StaticResource Gray100}, Dark=#2A2A3E}"
                   PlaceholderText="Ask Copilot something..."
                   SendButtonText="Send" />
</ContentPage>
